// Shared build settings for all local JammLab configurations.
// Signing, bundle identifiers, entitlements, and release distribution settings stay in the Xcode project for now.

PRODUCT_NAME = $(TARGET_NAME)
MACOSX_DEPLOYMENT_TARGET = 14.0
SWIFT_VERSION = 5.0
SDKROOT = macosx
CLANG_CXX_LANGUAGE_STANDARD = gnu++20
GCC_C_LANGUAGE_STANDARD = gnu17
